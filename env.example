# MongoDB Connection
MONGO_URL=mongodb+srv://OnlineReseller:aadil@onlinereseller.9jcjfin.mongodb.net/online-reseller?appName=OnlineReseller

# NextAuth Configuration
# For local development: http://localhost:3000
# For network access: http://<your-local-ip>:3000 (e.g., http://192.168.31.181:3000)
# Find your IP: ifconfig | grep "inet " | grep -v 127.0.0.1 (Mac/Linux)
#              or ipconfig (Windows - look for IPv4 Address)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# Socket.io (optional, defaults to NEXTAUTH_URL)
# For local development: http://localhost:3000
# For network access: http://<your-local-ip>:3000 (e.g., http://192.168.31.181:3000)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# Server Configuration (optional)
# HOSTNAME=0.0.0.0  # Uncomment to allow network access (default: 0.0.0.0)
# PORT=3000         # Server port (default: 3000)

